# ===========================================
# MediaTorrent Environment Configuration
# Internal use only (behind VPN)
# ===========================================

# General
NODE_ENV=production
TZ=UTC

# Ports
FRONTEND_PORT=3000
BACKEND_PORT=3001

# Backend
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRATION=7d
BCRYPT_ROUNDS=12

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mediatorrent
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=mediatorrent

# TMDB API
TMDB_API_KEY=your-tmdb-api-key-here

# qBittorrent
QBITTORRENT_HOST=qbittorrent
QBITTORRENT_PORT=8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminpassword

# Jellyfin (external instance)
JELLYFIN_URL=http://host.docker.internal:8096
JELLYFIN_API_KEY=your-jellyfin-api-key

# Upload limits
MAX_FILE_SIZE_MB=50000
CHUNK_SIZE_MB=10
ALLOWED_VIDEO_EXTENSIONS=.mp4,.mkv,.avi,.mov,.wmv,.flv,.webm,.m4v,.ts
ALLOWED_SUBTITLE_EXTENSIONS=.srt,.sub,.ass,.ssa,.vtt

# Media paths (inside containers)
MOVIES_PATH=/media/movies
TV_PATH=/media/tv
DOWNLOADS_PATH=/downloads
UPLOADS_TEMP_PATH=/uploads/temp

# Admin seed (first user - only way to create accounts is via admin panel)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@mediatorrent.local
ADMIN_PASSWORD=change-me-admin-password
